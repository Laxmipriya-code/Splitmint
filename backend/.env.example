SPLITMINT_ENVIRONMENT=development
SPLITMINT_DEBUG=false
SPLITMINT_DATABASE_URL=postgresql+psycopg://splitmint:splitmint@127.0.0.1:5432/splitmint
# Supabase direct DB hosts (db.<project-ref>.supabase.co:5432) require IPv6.
# On Render and other IPv4-only runtimes, use the Supavisor session pooler URL on port 5432 instead.
# Optional: set when runtime uses a pooler but migrations should use a different PostgreSQL host.
SPLITMINT_MIGRATION_DATABASE_URL=
SPLITMINT_TEST_DATABASE_URL=postgresql+psycopg://splitmint:splitmint@127.0.0.1:5432/splitmint_test
# Dangerous: if true and test DB URL equals runtime DB URL, tests will truncate runtime data.
SPLITMINT_ALLOW_SHARED_TEST_DATABASE=false
# Optional override. Leave empty to auto-disable prepared statements for Supabase transaction pooler (port 6543).
# Supavisor session mode on port 5432 keeps prepared statements enabled.
SPLITMINT_DB_DISABLE_PREPARED_STATEMENTS=
SPLITMINT_FRONTEND_ORIGIN=http://127.0.0.1:5173
SPLITMINT_JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-bytes
SPLITMINT_ACCESS_TOKEN_EXPIRE_MINUTES=30
SPLITMINT_REFRESH_TOKEN_EXPIRE_DAYS=30
SPLITMINT_AI_ENABLED=false
SPLITMINT_OPENAI_API_KEY=
SPLITMINT_OPENAI_MODEL=gpt-5-mini
SPLITMINT_LOG_LEVEL=INFO
